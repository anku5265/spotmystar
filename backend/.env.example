PORT=5000
NODE_ENV=development

# Supabase Configuration - DISCONNECTED
# Get these from: https://supabase.com > Your Project > Settings > API
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_ANON_KEY=your-anon-key-here

# Database Connection String - DISCONNECTED
# Get from: Supabase > Settings > Database > Connection String > Session Pooler
# Replace [YOUR-PASSWORD] with your actual database password
# DATABASE_URL=postgresql://postgres.xxxxx:your-password@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# JWT Secret (use any random long string)
JWT_SECRET=your_random_secret_key_make_it_long_and_secure

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Artist Panel URL
ARTIST_PANEL_URL=http://localhost:5175

# Admin Panel URL
ADMIN_PANEL_URL=http://localhost:5174

# ============================================
# INSTRUCTIONS TO RECONNECT:
# ============================================
# 1. Create new Supabase project at https://supabase.com
# 2. Go to Project Settings > Database
# 3. Copy the connection string (Session Pooler)
# 4. Uncomment and update the DATABASE_URL above
# 5. Go to Project Settings > API
# 6. Copy URL and anon key
# 7. Uncomment and update SUPABASE_URL and SUPABASE_ANON_KEY
# 8. Run: npm run seed (to populate initial data)
# ============================================
