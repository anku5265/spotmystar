PORT=5000
NODE_ENV=development

# Supabase Configuration
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key — REQUIRED for image upload (bucket management)
# Get from: Supabase Dashboard → Settings → API → service_role (secret) key
# IMPORTANT: Backend only — never expose on frontend!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database Connection String — Transaction Mode (port 6543) for Vercel serverless
# IMPORTANT: Use port 6543 (Transaction Mode), NOT 5432 (Session Mode)
# Session Mode hits Supabase free tier 15-connection limit on serverless
DATABASE_URL=postgresql://postgres.xxxxx:your-password@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# JWT Secret (use any random long string)
JWT_SECRET=your_random_secret_key_make_it_long_and_secure

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Artist Panel URL
ARTIST_PANEL_URL=http://localhost:5175

# Admin Panel URL
ADMIN_PANEL_URL=http://localhost:5174
